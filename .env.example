# --- Umumiy ---
APP_ENV=development
DEBUG=true

# --- Gemini ---
GEMINI_API_KEY=your_google_ai_studio_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_RETRIES=5
GEMINI_INITIAL_BACKOFF_SECONDS=1.0
GEMINI_MAX_BACKOFF_SECONDS=60.0
GEMINI_REQUEST_TIMEOUT_SECONDS=120.0

# --- Batching ---
BATCH_PARAGRAPH_SIZE=20

# --- Til aniqlash ---
LANGDETECT_CONFIDENCE_THRESHOLD=0.95

# --- Cache ---
CACHE_ENABLED=true
CACHE_MEMORY_MAX_ITEMS=2000
CACHE_REDIS_URL=redis://localhost:6379/0
CACHE_REDIS_TTL_SECONDS=2592000

# --- Fayl / konvertatsiya ---
WORK_DIR=/tmp/doc_translator
MAX_UPLOAD_SIZE_MB=50
LIBREOFFICE_BINARY=libreoffice
LIBREOFFICE_TIMEOUT_SECONDS=180
SCANNED_PDF_MIN_CHARS_PER_PAGE=20

# --- Celery / Redis broker ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
